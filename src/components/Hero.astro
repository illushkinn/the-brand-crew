---
// Hero section with animated background shapes
---

<div class="hero-problema-wrap">
  <div class="hero-shapes" aria-hidden="true">
    <div class="hero-shape"></div>
    <div class="hero-shape"></div>
    <div class="hero-shape"></div>
    <div class="hero-shape"></div>
    <div class="hero-shape"></div>
    <div class="hero-shape"></div>
    <div class="hero-shape"></div>
    <div class="hero-shape"></div>
    <div class="hero-shape"></div>
  </div>
  
  <section class="hero reveal" id="inicio" aria-label="Hero">
    <div class="hero-content">
      <h1 class="hero-title">
        Websites that <span class="text-terracota">actually work</span>
      </h1>
      <p class="hero-sub">
        For businesses that <span class="text-white">mean business</span>
      </p>
      <div class="hero-actions">
        <a
          href="https://wa.me/5491124063009?text=Hey%20Illya!%20I%20saw%20your%20site%20and%20I'd%20love%20to%20work%20together."
          target="_blank"
          rel="noopener"
          class="btn btn-empecemos btn-lg btn-premium"
        >
          Book a free call
        </a>
      </div>
      <p class="hero-meta">
        <span class="price-group">
          <span class="current-price">$240.000&nbsp;<small class="price-currency">ARS</small></span>
          <span class="strike-price" aria-label="Original price">$400.000</span>
        </span>
        <span class="price-group">
          <span>2 payments of <strong>$120.000</strong>&nbsp;<small class="price-currency">ARS</small></span>
        </span>
      </p>
      <p class="hero-b2b-tags">
        <span class="tag-b2b tag-outline">White-label partner</span>
      </p>
    </div>
  </section>
</div>

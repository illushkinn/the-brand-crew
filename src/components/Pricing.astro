---
// Pricing.astro - Pricing section with animated shapes and pricing card
---

<section class="section pricing reveal" id="precios" aria-label="Pricing">
  <div class="pricing-shapes" aria-hidden="true">
    <div class="pricing-shape"></div>
    <div class="pricing-shape"></div>
    <div class="pricing-shape"></div>
  </div>
  <span class="section-label mono text-terracota">Pricing</span>
  <h2 class="section-title"><span class="text-verde">A steal</span>.</h2>
  <div class="glass-card pricing-card">
    <div class="pricing-line">
      <span class="pricing-line-label">Design + Development<br><small>+ Domain (2 years)</small></span>
      <span class="pricing-line-price">
        <span class="strike-price pricing-strike">$400.000 ARS</span>
        <span class="pricing-current">$240.000&nbsp;<small class="price-currency">ARS</small></span>
      </span>
    </div>
    <div class="pricing-split">
      <div class="pricing-split-item">
        <div class="amount">
          <span class="pricing-current">$120.000&nbsp;<small class="price-currency">ARS</small></span>
        </div>
        <div class="label">At start</div>
      </div>
      <div class="pricing-split-item">
        <div class="amount">
          <span class="pricing-current">$120.000&nbsp;<small class="price-currency">ARS</small></span>
        </div>
        <div class="label">At delivery</div>
      </div>
    </div>

    <div class="pricing-includes">
      <h4>Includes</h4>
      <ul>
        <li>✓ Custom design</li>
        <li>✓ .com domain</li>
        <li>✓ Fast hosting</li>
        <li>✓ SEO</li>
        <li>✓ Multiple revision rounds</li>
        <li>✓ 24/7 WhatsApp support</li>
        <li>✓ Responsive on all devices</li>
        <li>✓ SSL/HTTPS</li>
      </ul>
    </div>
    <a href="https://wa.me/5491124063009?text=Hey%20Illya!%20I%20saw%20your%20site%20and%20I'd%20love%20to%20work%20together." target="_blank" rel="noopener" class="btn btn-empecemos btn-lg btn-full-width">
      Let's go online
    </a>
  </div>
</section>
